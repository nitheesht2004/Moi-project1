# ──────────────────────────────────────────────────────────────────────
# API Environment Variables — EXAMPLE (copy to api/.env for local dev)
# ──────────────────────────────────────────────────────────────────────
#
# For Vercel deployment, add these in:
#   Project Settings → Environment Variables
#
# For local development, create a file at:
#   api/.env
# and copy the values below.

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details.
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Authentication ─────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_at_least_64_chars

# Token expiry (optional, defaults to 7d)
JWT_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────────────
# Your Vercel deployment URL (e.g. https://yourapp.vercel.app)
# Leave blank to allow only localhost during development.
CORS_ORIGIN=https://yourapp.vercel.app

# ── Runtime ────────────────────────────────────────────────────────────
NODE_ENV=production
